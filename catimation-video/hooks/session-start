#!/usr/bin/env bash
# SessionStart hook for catimation-video plugin.
# Injects sd2-pe (Seedance 2.0 Prompt Optimizer) as the FOUNDATION / FALLBACK
# for all video + prompt generation. Everything else is a derivation on top.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

sd2_content=$(cat "${PLUGIN_ROOT}/skills/sd2-pe/SKILL.md" 2>&1 || echo "Error reading sd2-pe skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

sd2_escaped=$(escape_for_json "$sd2_content")
session_context="<EXTREMELY_IMPORTANT>\nCATIMATION 视频出片插件已启用。\n\nsd2-pe(Seedance 2.0 Prompt Optimizer)是【视频与提示词的总兜底和起点】:只要任务涉及生成视频或写视频提示词(包括你自发配视频),都必须先用 sd2-pe 把需求/草稿/多模态 JSON 走完 Step 0→Step 4,产出工程化提示词,再叠加衍生技法(seedance-video-craft 模型对齐/配额、director-orchestrator 成套分镜 13 维定位、storyboard-* 逐镜打磨),最后交 catimation-video 的 generate_video 出片;剪辑拼接用 ffmpeg-win。命令:/sd2 直接优化提示词,/gen-video 出片,/edit-video 后期。\n\n【制片纪律·硬门 — 角色片/多镜必守(纲要;完整规则见 catimation-video 与 film-studio 技能正文,按需用 Skill 工具加载)】\n只要视频里有反复出现的角色、或不止一个镜头/事件,生成前你 MUST 依次:\n1) 人物卡:每个出镜角色先建 大头照(正脸无表情)+ 全身照,存人像库 asset:// 作唯一身份锚,全片复用;禁用三视图/多视图。缺图先 generate_image 补。\n2) 故事板/分镜:非单镜先排 镜头1/2/…(运镜→主体动作/表情→位置/空间→音频四要素),给用户过一遍再生成;一镜一运镜、用序号不写绝对秒数。\n3) 资产齐备门(硬):备齐才调 generate_video。缺资产不要干等也不要硬生,先报缺口清单,再三选一逐项处理 —— ① 先在项目 assets//人像库找现成的;② 非身份关键(环境/场景/氛围/通用道具/空镜)用 generate_image 自主补图入库;③ 身份/意图关键(特定真人/指定角色IP/品牌Logo/特定真实产品)才 ask_user 请用户提供。绝不先生成再补。\n4) 用上全部可用资产:图片+参考视频+音乐/音频都是全能参考素材,一个别落下,有素材却纯文字=错;每次生成要用的素材复制进一个新建专属夹(一镜一夹,如 assets/jobs/S01_<slug>/)便于复用与检查。\n5) 写 prompt 前 MUST 先用 skill 渐进式编写:director-orchestrator(STEP0 反问)+ sd2-pe + storyboard-video-prompt-optimization,物理可复现参数(焦段/光圈/色温/运镜)优先于情绪形容词,并把已备素材逐一绑进 prompt;禁止脱离 skill+素材凭记忆硬写。\n轻量例外:单图「让它动起来」这类一次性简单请求,把那张图当参考/首帧直接动起来即可,不必强排人物卡/故事板。\n\n下面是 sd2-pe 技能全文(总兜底,务必遵循其八大要素/路径A·B/兜底包/强制约束):\n\n${sd2_escaped}\n</EXTREMELY_IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
